<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Display reachability monitor (detection / alerting only).

        Listens on TCP 9999 for the display's reverse-shell dial-in and logs
        whether the heartbeat (images/last-poll.txt) is fresh or stale. It
        does NOT send recovery commands: active recovery is owned by the
        display's own app_watchdog.sh (see deploy/display/), which detects
        the app-layer ENETUNREACH condition locally and escalates to a full
        reboot. This daemon used to send an eth0-bounce fix; repeated bounces
        caused the 2026-06-06 outage, so recovery was moved on-device.

        Install:
          cp deploy/com.e-newspaper.auto-recover.plist ~/Library/LaunchAgents/
          launchctl load ~/Library/LaunchAgents/com.e-newspaper.auto-recover.plist

        Tail dial-ins / stale-heartbeat warnings:
          tail -F auto-recover.err.log | grep -E "stale|healthy"

        Stop temporarily (e.g. to use tools/remote_shell.py manually):
          launchctl unload ~/Library/LaunchAgents/com.e-newspaper.auto-recover.plist

        Note: deploy/install.sh rewrites __INSTALL_DIR__ before copying.
    -->
    <key>Label</key>
    <string>com.e-newspaper.auto-recover</string>

    <key>WorkingDirectory</key>
    <string>__INSTALL_DIR__</string>

    <key>ProgramArguments</key>
    <array>
        <string>__INSTALL_DIR__/.venv/bin/python</string>
        <string>-u</string>
        <string>src/auto_recover.py</string>
    </array>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>__INSTALL_DIR__/auto-recover.log</string>
    <key>StandardErrorPath</key>
    <string>__INSTALL_DIR__/auto-recover.err.log</string>
</dict>
</plist>
